{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext", // or "ESNext"
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
